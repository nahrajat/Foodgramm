PORT=8080
NODE_ENV=development
mongo_url=mongodb+srv://<user>:<password>@<cluster>/<db>
jwt_secret=replace-with-strong-secret
IMAGEKIT_PUBLIC_KEY=your-imagekit-public-key
IMAGEKIT_PRIVATE_KEY=your-imagekit-private-key
